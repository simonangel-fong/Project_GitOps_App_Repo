<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- No tab characters in source files -->
    <module name="FileTabCharacter"/>

    <!-- Max line length -->
    <module name="LineLength">
        <property name="max" value="120"/>
    </module>

    <module name="TreeWalker">

        <!-- Naming conventions -->
        <module name="TypeName"/>               <!-- PascalCase for classes -->
        <module name="MethodName"/>             <!-- camelCase for methods -->
        <module name="ParameterName"/>          <!-- camelCase for parameters -->
        <module name="LocalVariableName"/>      <!-- camelCase for local vars -->
        <module name="MemberName"/>             <!-- camelCase for fields -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- Imports -->
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="AvoidStarImport"/>

        <!-- Braces -->
        <module name="LeftCurly"/>              <!-- opening brace on same line -->
        <module name="RightCurly"/>             <!-- closing brace on own line -->
        <module name="NeedBraces"/>             <!-- always use braces for blocks -->

        <!-- Whitespace -->
        <module name="WhitespaceAfter"/>
        <module name="WhitespaceAround"/>

        <!-- Indentation: 4 spaces -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="caseIndent" value="4"/>
        </module>

        <!-- Code quality -->
        <module name="EmptyBlock"/>             <!-- no empty catch/finally blocks -->
        <module name="EmptyStatement"/>         <!-- no lone semicolons -->
        <module name="EqualsHashCode"/>         <!-- if equals(), must have hashCode() -->
        <module name="SimplifyBooleanExpression"/>
        <module name="StringLiteralEquality"/> <!-- use .equals() not == for Strings -->

    </module>
</module>
